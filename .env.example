# ===========================================
# Faces of Plants - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.
# Never commit .env.local to version control.

# -------------------------------------------
# Authentication
# -------------------------------------------
# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret-here

# Google OAuth (optional - leave as placeholder to disable)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# GitHub OAuth (optional - leave as placeholder to disable)
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder

# -------------------------------------------
# Database (DynamoDB)
# -------------------------------------------
# Auto-configured by SST in production.
# For local dev, these are set by `sst dev`.
AUTH_JS_TABLE_NAME=
DATA_SOURCES_TABLE=
USER_COLLECTIONS_TABLE=
CACHE_TABLE=

# -------------------------------------------
# LLM (Mistral AI)
# -------------------------------------------
LLM_PROVIDER=mistral
LLM_API_KEY=your-mistral-api-key
LLM_ENDPOINT=https://api.mistral.ai/v1
LLM_MODEL=mistral-large-latest

# -------------------------------------------
# GBIF API
# -------------------------------------------
# No API key required - GBIF is open access.
GBIF_API_URL=https://api.gbif.org/v1
GBIF_USER_AGENT=FaceOfPlants/0.4.1 (https://facesofplants.org; facesofplants@gmail.com)

# -------------------------------------------
# Admin
# -------------------------------------------
ADMIN_API_TOKEN=your-admin-token-here

# -------------------------------------------
# AWS (production only - auto-configured by SST)
# -------------------------------------------
AWS_REGION=eu-central-1
