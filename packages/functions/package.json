{
  "name": "@faces-of-plants/functions",
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc -noEmit",
    "lint": "eslint . --ext .ts",
